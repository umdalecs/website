---
import { Icon } from 'astro-icon/components';

const stacks = [
  {
    name: 'Programming Languages',
    items: [
      {
        title: 'TS/JS',
        icon: 'logos:typescript-icon',
      },
      {
        title: 'Java',
        icon: 'logos:java',
      },
      {
        title: 'C#',
        icon: 'logos:c-sharp',
      },
      {
        title: 'SQL',
        icon: 'lucide:database',
      },
      {
        title: 'Python',
        icon: 'logos:python',
      },
      {
        title: 'PHP',
        icon: 'logos:php',
      },
      {
        title: 'Go',
        icon: 'logos:go',
      },
    ]
  },
  {
    name: 'Frameworks',
    items: [
      {
        title: 'Astro',
        icon: 'logos:astro-icon',
      },
      {
        title: 'React',
        icon: 'logos:react',
      },
      {
        title: 'Next.js',
        icon: 'logos:nextjs-icon',
      },
      {
        title: 'Angular',
        icon: 'logos:angular-icon',
      },
      {
        title: 'Express',
        icon: 'devicon:express',
      },
      {
        title: 'Spring',
        icon: 'logos:spring-icon',
      },
      {
        title: '.NET',
        icon: 'logos:dotnet',
      },
      {
        title: 'Gin',
        icon: 'logos:gin',
      },
      {
        title: 'Tailwind CSS',
        icon: 'logos:tailwindcss-icon',
      },
    ],
  },
  {
    name: 'Tools',
    items: [
      {
        title: 'Git',
        icon: 'logos:git-icon',
      },
      {
        title: 'GitHub',
        icon: 'logos:github-icon',
      },
      {
        title: 'GitLab',
        icon: 'logos:gitlab-icon',
      },
      {
        title: 'Docker',
        icon: 'logos:docker-icon',
      },
      {
        title: 'PostgreSQL',
        icon: 'logos:postgresql',
      },
      {
        title: 'MongoDB',
        icon: 'logos:mongodb-icon',
      },
    ],
  },
];
---

<section class="skills min-h-full max-w-3xl flex flex-col flex-center justify-center items-center mx-auto px-4 fade-on-scroll" id="skills">
  <h2 class="text-4xl text-foreground-accent2 mb-4">Skills</h2>
  <p class="text-center mb-4">
    I have experience with a variety of technologies and tools, including
    JavaScript, TypeScript, React, Node.js, Astro, and more. I'm always eager
    to learn new technologies and expand my skill set.
  </p>
  <article>
    {
    stacks.map((stack) => (
      <h3 class="mb-2">{stack.name}</h3>
      <div class="flex flex-wrap gap-2 mb-2">
          {stack.items.map((item) => (
            <span class="bg-background-light border rounded-sm py-2 px-1 flex items-center gap-1">
                <Icon size="1rem" name={item.icon} />
                <span>{item.title}</span>
            </span>
          ))}
      </div>
    ))
  }
  </article>
</section>
