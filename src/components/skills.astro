---
import { Icon } from 'astro-icon/components';

const stacks = [
  {
    name: 'Programming Languages',
    items: [
      {
        title: 'TS/JS',
        icon: 'logos:typescript-icon',
      },
      {
        title: 'Java',
        icon: 'logos:java',
      },
      {
        title: 'C#',
        icon: 'logos:c-sharp',
      },
      {
        title: 'SQL',
        icon: 'lucide:database',
      },
    ]
  },
  {
    name: 'Frameworks',
    items: [
      {
        title: 'Astro',
        icon: 'logos:astro-icon',
      },
      {
        title: 'React',
        icon: 'logos:react',
      },
      {
        title: 'Next.js',
        icon: 'logos:nextjs-icon',
      },
      {
        title: '.NET',
        icon: 'logos:dotnet',
      },
      {
        title: 'Tailwind CSS',
        icon: 'logos:tailwindcss-icon',
      },
    ],
  },
  {
    name: 'Tools',
    items: [
      {
        title: 'Git',
        icon: 'logos:git-icon',
      },
      {
        title: 'GitHub',
        icon: 'logos:github-icon',
      },
      {
        title: 'GitLab',
        icon: 'logos:gitlab-icon',
      },
      {
        title: 'Docker',
        icon: 'logos:docker-icon',
      },
      {
        title: 'PostgreSQL',
        icon: 'logos:postgresql',
      },
      {
        title: 'MongoDB',
        icon: 'logos:mongodb-icon',
      },
    ],
  },
];
---

<section class="skills min-h-full max-w-3xl flex flex-col justify-center items-center mx-auto px-4 mt-20 fade-on-scroll" id="skills">
  <h2 class="text-4xl font-mono text-accent-purple glow-purple mb-6 transition-all duration-300 hover:glow-purple-intense">
    Skills
  </h2>
  <p class="text-center text-foreground/80 mb-8 max-w-2xl leading-relaxed">
    I work with a modern stack of languages and frameworks, including
    TypeScript, React, .NET, and Docker. I'm always looking to expand my
    technical toolkit.
  </p>
  <article class="w-full">
    {
    stacks.map((stack) => (
      <h3 class="text-2xl font-mono text-accent-pink glow-pink mt-8 mb-4 transition-all duration-300 hover:glow-pink-intense">
        {stack.name}
      </h3>
      <div class="flex flex-wrap gap-4 mb-8">
          {stack.items.map((item) => (
            <span class="bg-background-secondary/85 border border-accent-purple/35 rounded-xl py-3 px-5 flex items-center gap-3.5 font-mono text-base md:text-lg backdrop-blur-md transition-all duration-300 hover:border-accent-purple hover:box-glow-purple hover:-translate-y-1 hover:text-white">
                <Icon size="1.85rem" class="drop-shadow-icon-contrast shrink-0" name={item.icon} />
                <span class="font-medium text-foreground tracking-wide">{item.title}</span>
            </span>
          ))}
      </div>
    ))
  }
  </article>
</section>
