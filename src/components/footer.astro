---
import { Icon } from "astro-icon/components";
const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-accent-blue/10 bg-background-secondary/30 backdrop-blur-md py-8 mt-20">
  <div class="max-w-4xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-foreground-ghost">
    
    <!-- Left side: copyright and stack info -->
    <div class="flex flex-col items-center md:items-start gap-1 font-mono">
      <p class="text-foreground/80">
        &copy; {currentYear} Alejandro Flores. All rights reserved.
      </p>
      <p class="text-xs text-foreground/45 flex items-center gap-1.5">
        Built with 
        <a href="https://astro.build/" target="_blank" rel="noopener noreferrer" class="hover:text-accent-blue transition-colors">Astro</a> 
        &amp; 
        <a href="https://tailwindcss.com/" target="_blank" rel="noopener noreferrer" class="hover:text-accent-pink transition-colors">Tailwind CSS</a>
      </p>
    </div>

    <!-- Right side: back to top button -->
    <div class="flex items-center gap-4">
      <a 
        href="#hero" 
        class="flex items-center gap-2 py-2 px-4 rounded-lg bg-background-accent/60 border border-accent-purple/20 text-accent-purple hover:text-white hover:border-accent-purple hover:bg-accent-purple/10 hover:-translate-y-0.5 hover:box-glow-purple transition-all duration-300 font-mono text-xs cursor-pointer"
      >
        <Icon name="lucide:arrow-up" class="text-base" />
        Back to Top
      </a>
    </div>

  </div>
</footer>
