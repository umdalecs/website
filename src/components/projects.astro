---
import { Image } from "astro:assets";

const projects: {
  name: string;
  description: string;
  image: ImageMetadata;
  link: string | null;
}[] = [];
---

{
  (
    <section
      class="min-h-full max-w-4xl flex flex-col flex-center justify-center items-center mx-auto px-4 fade-on-scroll"
      id="projects"
    >
      <h2 class="text-4xl text-foreground-accent2 mb-4">Projects</h2>
      {projects.length < 1 ? (
        <p class="p-4 text-center">
          I haven't jet uploaded projects for this portfolio but feel free to
          check my
          <a
            href="https://github.com/umdalecs/"
            class="underline hover:text-foreground-accent"
          >
            github
          </a>
          :)
        </p>
      ) : (
        <>
          <p class="p-4 text-center">
            Here are some of my recent projects, feel free to explore:
          </p>
          {projects.map((project) => (
            <article class="bg-background-secondary border rounded-sm flex sm:flex-col sm:items-center">
              <Image
                class="w-40 h-auto rounded-l-xs aspect-square sm:w-full sm:rounded-l-1 sm:aspect-auto sm:last:ml-0 sm:last:mt-4"
                src={project.image}
                alt={project.name}
              />
              <div class="p-4 text-left last:ml-auto w-fit">
                <h3 class="text-2xl text-foreground-accent3 mb-4">
                  {project.name}
                </h3>
                <p>{project.description}</p>
                {project.link && (
                  <a
                    class="text-foreground-accent bg-background-accent"
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    View Project
                  </a>
                )}
              </div>
            </article>
          ))}
        </>
      )}
    </section>
  )
}
