---
import { Image } from "astro:assets";

const projects: {
  name: string;
  description: string;
  image: ImageMetadata;
  link: string | null;
}[] = [];
---

{
  (
    <section
      class="min-h-full max-w-4xl flex flex-col justify-center items-center mx-auto px-4 mt-20 fade-on-scroll"
      id="projects"
    >
      <h2 class="text-4xl font-mono text-accent-purple glow-purple mb-6 transition-all duration-300 hover:glow-purple-intense">
        Projects
      </h2>
      {projects.length < 1 ? (
        <p class="p-4 text-center text-foreground/80">
          I haven't yet uploaded projects for this portfolio but feel free to
          check my
          <a
            href="https://github.com/umdalecs/"
            class="underline text-accent-blue glow-blue hover:glow-blue-medium px-1"
          >
            github
          </a>
          :)
        </p>
      ) : (
        <>
          <p class="p-4 text-center text-foreground/85 mb-6">
            Here are some of my recent projects, feel free to explore:
          </p>
          {projects.map((project) => (
            <article class="bg-background-secondary/60 border border-accent-blue/15 rounded-xl backdrop-blur-lg flex overflow-hidden sm:flex-col sm:items-center transition-all duration-300 hover:border-accent-blue hover:box-glow-blue hover:-translate-y-1 w-full">
              <Image
                class="w-40 h-auto aspect-square sm:w-full sm:rounded-t-xl sm:aspect-auto object-cover transition-transform duration-500 hover:scale-105"
                src={project.image}
                alt={project.name}
              />
              <div class="p-6 text-left w-full flex flex-col justify-between">
                <div>
                  <h3 class="text-2xl font-mono text-accent-pink glow-pink mb-2 transition-all duration-300 hover:glow-pink-intense">
                    {project.name}
                  </h3>
                  <p class="text-foreground/80 leading-relaxed">{project.description}</p>
                </div>
                {project.link && (
                  <div class="mt-4 last:ml-auto w-fit">
                    <a
                      class="inline-block text-background font-semibold bg-accent-blue border border-accent-blue py-2 px-5 rounded-lg transition-all duration-300 shadow-blue-glow hover:bg-transparent hover:text-accent-blue hover:box-glow-blue hover:glow-blue hover:-translate-y-0.5"
                      href={project.link}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      View Project
                    </a>
                  </div>
                )}
              </div>
            </article>
          ))}
        </>
      )}
    </section>
  )
}
