---
import {Icon} from "astro-icon/components";

import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";

import profileImage from "../assets/profile.png";

import Programming from "./_programming.astro";

const links: { name: string; href: string; icon: string; newPage: boolean }[] = [
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/ing-alejandrof/",
    icon: "lucide:linkedin",
    newPage: true,
  },
  {
    name: "GitHub",
    href: "https://github.com/umdalecs",
    icon: "lucide:github",
    newPage: true,
  },
  {
    name: "Contact",
    href: "mailto:umdalecs@proton.me",
    icon: "lucide:mail",
    newPage: false,
  },
  {
    name: "Skills",
    href: "/#skills",
    icon: "lucide:star",
    newPage: false,
  },
];

const projects: {
  name: string;
  description: string;
  image: ImageMetadata;
  link: string | null;
}[] = [
  {
    name: "Personal Portfolio",
    description:
      "A personal portfolio website built with Astro, showcasing my projects and skills.",
    image: profileImage,
    link: "https://github.com/umdalecs/umdalecs.github.io",
  },
];

if (projects.length > 0) {
  links.splice(3, 0, {
    name: "Projects",
    href: "/#projects",
    icon: "lucide:folder",
    newPage: false,
  });
}

---

<Layout title="umdalecs">
  <main class="hero fade-on-scroll" id="hero">
    <Image src={profileImage} alt="Profile picture" width={200} height={200} />
    <h1>Alejandro Flores</h1>
    <h3>FullStack Developer & Student</h3>
    <p>
      I'm a passionate full-stack developer with a love for learning and
      creating. I enjoy working on projects that challenge me and allow me to
      grow my skills. I'm always looking for new opportunities to collaborate
      and build amazing things together.
    </p>
    <article class="links">
      {
        links.map((link) => (
          <a
            class="link"
            href={link.href}
            target={link.newPage ? "_blank" : "_self"}
            rel={link.newPage ? "noopener noreferrer" : undefined}
          >
            <Icon name={link.icon} />
            {link.name}
          </a>
        ))
      }
    </article>
  </main>

  {
    projects.length > 0 && (
      <section class="projects fade-on-scroll" id="projects">
        <h2>Projects</h2>
        <p>Here are some of my recent projects, feel free to explore:</p>
        {projects.map((project) => (
          <article class="project">
            <Image src={project.image} alt={project.name} />
            <div>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              {project.link && (
                <a
                  class="link"
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  View Project
                </a>
              )}
            </div>
          </article>
        ))}
      </section>
    )
  }

  <section class="skills fade-on-scroll" id="skills">
    <h2>Skills</h2>
    <p>
      I have experience with a variety of technologies and tools, including
      JavaScript, TypeScript, React, Node.js, Astro, and more. I'm always eager
      to learn new technologies and expand my skill set.
    </p>
    <Programming />
  </section>
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    text-align: center;

    align-items: center;
    justify-content: center;

    margin-inline: auto;

    max-width: 35rem;
    height: 100%;
  }

  .hero > img {
    border-radius: 50%;
    border: 2px solid var(--foreground);
  }

  h1,
  h2,
  h3 {
    font-family: "JetBrainsMono", monospace;
  }

  h1 {
    font-size: 2.5rem;
    margin-block: 1rem;
  }

  h2 {
    font-size: 2rem;
    margin-block: 1rem;
  }

  h3 {
    font-size: 1.5rem;
    margin-block: 0.25rem;
  }

  .links {
    display: flex;
    width: 100%;
    gap: 1rem;
    margin-block: 1rem;
  }

  .links:hover .link {
    color: var(--foreground-ghost);
  }

  .link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem;
    border-radius: 0.25rem;
    transition: color 0.3s ease;
  }

  .links .link:hover {
    color: var(--foreground-accent);
    background: var(--background-accent);
  }

  .projects {
    display: flex;
    flex-direction: column;
    text-align: center;

    align-items: center;

    margin-inline: auto;

    min-height: 100%;
    max-width: 35rem;
  }

  .projects > h2 {
    margin-top: 4rem;
  }

  .projects > p {
    padding: 1rem;
  }

  .project {
    background-color: var(--background-secondary);
    border-radius: 0.25rem;
    display: flex;
  }

  .project > img {
    width: 10rem;
    height: auto;
    border-top-left-radius: 0.25rem;
    border-bottom-left-radius: 0.25rem;
    aspect-ratio: 1/1;
  }

  .project > div {
    padding: 1rem;
    text-align: left;
  }

  .project > div > :last-child {
    margin-left: auto;
    width: fit-content;
  }

  .skills {
    display: flex;
    flex-direction: column;

    align-items: center;

    margin-inline: auto;

    min-height: 100%;
    max-width: 35rem;
  }

  .skills > h2 {
    margin-top: 4rem;
  }

  .skills > p {
    text-align: center;
  }
</style>
